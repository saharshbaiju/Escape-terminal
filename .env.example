# Copy to .env.local for local dev, OR set these in Vercel → Project → Settings →
# Environment Variables. All VITE_* vars are baked into the browser bundle at
# build time, so they MUST be public values only.
#
# The Supabase project URL + a PUBLIC client key. Safe to expose — Row Level
# Security (supabase/migrations/0001_init.sql) restricts the key to inserting a
# run and reading the board. Use the newer publishable key (sb_publishable_...)
# or the legacy anon key (eyJ...). Leave blank to use a local-only leaderboard.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=   # alternative to the publishable key
VITE_SUPABASE_TABLE=leaderboard
